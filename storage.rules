rules_version = '2';

// Craft rules based on data in your Firestore database
// allow write: if firestore.get(
//    /databases/(default)/documents/users/$(request.auth.uid)).data.isAdmin;
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    match /profile_pictures/{userId}/{allPaths=**} {
      // Anyone can read profile pictures
      allow read: if true;
      // Only the owner can upload/update/delete their profile pictures
      // Must be an image less than 5MB
      allow write: if isAuthenticated() 
                   && request.auth.uid == userId 
                   && request.resource.size < 5 * 1024 * 1024 
                   && request.resource.contentType.matches('image/.*');
      allow delete: if isAuthenticated() && request.auth.uid == userId;
    }

    match /post_images/{userId}/{allPaths=**} {
      // Anyone authenticated can view post images
      allow read: if isAuthenticated();
      // Only the owner can upload/update/delete
      // Must be an image less than 10MB
      allow write: if isAuthenticated() 
                   && request.auth.uid == userId
                   && request.resource.size < 10 * 1024 * 1024 
                   && request.resource.contentType.matches('image/.*');
      allow delete: if isAuthenticated() && request.auth.uid == userId;
    }
  }
}
